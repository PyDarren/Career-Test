# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (MySQL - production)
DB_NAME=caretest
DB_USER=caretest
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis (cache - production)
REDIS_URL=redis://127.0.0.1:6379/1

# WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://example.com/api/payment/wechat/notify/

# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://example.com/api/payment/alipay/notify/
ALIPAY_SANDBOX=true

# Sentry (error tracking)
SENTRY_DSN=

# Security Keys (M4 — 必须在生产环境设置真实值)
# AES-256 加密密钥（测评答案加密存储，32 字节）
AES_ENCRYPTION_KEY=change-me-to-a-32-byte-aes-key
# HMAC-SHA256 签名密钥（订单防篡改，防线 1）
HMAC_SECRET_KEY=change-me-to-a-hmac-secret-key

# CORS (production whitelist)
CORS_ALLOWED_ORIGINS=https://example.com
