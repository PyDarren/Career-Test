# ============================================================================
# Anchor — 环境变量模板
#
# 品牌：Anchor
# 项目：career_test
#
# 用法：复制本文件为 .env 并填写真实值
#   cp .env.example .env
#
# 警告：
#   - .env 文件已被 .gitignore 忽略，切勿提交到版本控制
#   - 本文件仅作模板，不含真实密钥
#   - 生产环境请使用真实、足够强度的密钥
# ============================================================================

# ---------------------------------------------------------------------------
# Django 核心配置
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=False
ALLOWED_HOSTS=huajizhice.com

# ---------------------------------------------------------------------------
# 数据库（MySQL - 生产环境）
# ---------------------------------------------------------------------------
DB_NAME=caretest
DB_USER=caretest
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ---------------------------------------------------------------------------
# Redis（缓存 & Celery Broker - 生产环境）
# ---------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/1

# ---------------------------------------------------------------------------
# Sentry（错误追踪，非空时自动初始化）
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# 安全密钥（M4 — 必须在生产环境设置真实值）
# ---------------------------------------------------------------------------
# AES-256 加密密钥（测评答案加密存储，32 字节）
AES_ENCRYPTION_KEY=change-me-to-a-32-byte-aes-key
# HMAC-SHA256 签名密钥（订单防篡改，防线 1）
HMAC_SECRET_KEY=change-me-to-a-hmac-secret-key
# 订单签名密钥（订单完整性校验）
ORDER_SIGNATURE_SECRET=change-me-to-an-order-signature-secret

# ---------------------------------------------------------------------------
# 微信支付
# ---------------------------------------------------------------------------
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=https://huajizhice.com/api/payment/wechat/notify/
WECHAT_CERT_PATH=

# ---------------------------------------------------------------------------
# 支付宝
# ---------------------------------------------------------------------------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://huajizhice.com/api/payment/alipay/notify/

# ---------------------------------------------------------------------------
# 邮件（SMTP）
# ---------------------------------------------------------------------------
DEFAULT_FROM_EMAIL=noreply@huajizhice.com
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=True

# ---------------------------------------------------------------------------
# CORS（生产环境白名单）
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://huajizhice.com
