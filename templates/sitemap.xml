<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'home' %}</loc>
        <lastmod>{% now "Y-m-d" %}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>1.0</priority>
    </url>

    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'assessment' %}</loc>
        <lastmod>{% now "Y-m-d" %}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.9</priority>
    </url>

    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'help' %}</loc>
        <lastmod>{% now "Y-m-d" %}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.6</priority>
    </url>

    <url>
        <loc>{{ request.scheme }}://{{ request.get_host }}{% url 'settings' %}</loc>
        <lastmod>{% now "Y-m-d" %}</lastmod>
        <changefreq>monthly</changefreq>
        <priority>0.4</priority>
    </url>

</urlset>
